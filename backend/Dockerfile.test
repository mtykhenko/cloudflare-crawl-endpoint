# Multi-stage build for Python backend testing
FROM python:3.11-alpine AS builder

# Set working directory
WORKDIR /app

# Install build dependencies
RUN apk add --no-cache gcc musl-dev libffi-dev

# Copy requirements first for better caching
COPY requirements.txt requirements-dev.txt ./

# Install Python dependencies (both production and dev)
RUN pip install --no-cache-dir --user -r requirements.txt -r requirements-dev.txt


# Final stage
FROM python:3.11-alpine

# Set working directory
WORKDIR /app

# Install runtime dependencies
RUN apk add --no-cache libffi curl

# Copy Python dependencies from builder
COPY --from=builder /root/.local /home/appuser/.local

# Create non-root user and set permissions
RUN adduser -D -u 1000 appuser && \
    chown -R appuser:appuser /app && \
    chown -R appuser:appuser /home/appuser/.local

# Switch to non-root user
USER appuser

# Add local bin to PATH
ENV PATH=/home/appuser/.local/bin:$PATH

# Set Python path
ENV PYTHONPATH=/app

# Default command runs tests
CMD ["pytest", "--cov=app", "--cov-report=html:/app/tests/reports/coverage", "--cov-report=term-missing", "--cov-report=xml:/app/tests/reports/coverage.xml", "--junit-xml=/app/tests/reports/junit/results.xml", "-v"]